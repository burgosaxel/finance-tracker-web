# Non-secret Functions runtime config
# Sensitive values stay in Firebase Functions secrets:
#   firebase functions:secrets:set PLAID_CLIENT_ID
#   firebase functions:secrets:set PLAID_SECRET
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US

# Optional for OAuth / hosted flows or webhook processing
PLAID_REDIRECT_URI=
PLAID_WEBHOOK_URL=
